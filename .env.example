# Copy to .env and fill in values. Never commit .env or .env.production.

VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Local scripts and Supabase CLI only — never expose in the frontend bundle.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Database password for `npm run db:repair-partial` / `supabase db push` (Dashboard → Settings → Database)
# SUPABASE_DB_PASSWORD="your-database-password"

# PostHog product analytics (EU Cloud). Key is public — safe in frontend.
# Add to Vercel environment variables for production.
VITE_POSTHOG_KEY="phc_xxxxxxxxxxxx"

# Optional: enable dev tools on a non-local deployment (see DevToolsDropdown).
# VITE_APP_DEV_BUILD=true

# Optional: deploy sync-dev-mode edge function, then set to call it from the app.
# VITE_SYNC_DEV_MODE_EDGE=true

# Optional: password for DevTools → Switch test user (TEST-01 … TEST-06).
# VITE_DEV_TEST_PASSWORD=TestPassword123!
